package views

templ Login() {
	@Layout("Login - StashForMe") {
		<h2>Login</h2>
		<p>Enter your phone number to get started.</p>

		<form method="POST" action="/auth/send-code">
			<p>
				<label for="phone">Phone Number</label><br/>
				<input
					type="tel"
					id="phone"
					name="phone"
					placeholder="555-123-4567"
					required
					autocomplete="tel"
				/>
			</p>
			<p>
				<button type="submit">Send Code</button>
				<button type="button" data-action="passkey-login">Use Passkey</button>
			</p>
		</form>
	}
}
