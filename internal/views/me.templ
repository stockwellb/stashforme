package views

import "stashforme/internal/auth"

templ Me(user *auth.User) {
	@Layout("My Profile - StashForMe") {
		<h2>My Profile</h2>

		@ProfileCard(user)

		<nav aria-label="Profile navigation">
			<ul>
				<li><a href="/my/stash">My Stash</a></li>
				<li><a href="/my/account">Account Settings</a></li>
			</ul>
		</nav>

		<form method="POST" action="/auth/logout">
			<button type="submit">Logout</button>
		</form>
	}
}
