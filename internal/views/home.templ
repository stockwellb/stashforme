package views

templ Home() {
	@Layout("StashForMe - Save and Share Links") {
		<h2>Save and share links via SMS</h2>

		<section>
			<h3>How it works</h3>
			<ol>
				<li>Save links to your stash</li>
				<li>Organize them into lists</li>
				<li>Share lists with anyone via SMS</li>
			</ol>
		</section>

		<p>
			<a href="/login">Get Started</a>
		</p>
	}
}
